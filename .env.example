# Copy this file to .env and fill in your real values

# Portainer configuration
# Example: http://localhost:9000 or https://portainer.example.com
PORTAINER_URL=http://localhost:9000
# Your Portainer API key or token. If you use the API key header name rather than Authorization, set PORTAINER_AUTH_HEADER to X-Api-Key
PORTAINER_KEY=your-portainer-api-key
# Optional header name to send the key in (default in client: Authorization: Bearer <key>)
# Set to X-Api-Key if Portainer expects that header instead
PORTAINER_AUTH_HEADER=Authorization

# Sonarr configuration
# Example: http://localhost:8989
SONARR_URL=http://localhost:8989
# Sonarr API key (sent as X-Api-Key header)
SONARR_API_KEY=your-sonarr-api-key

